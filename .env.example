###################################
# Server Configuration
###################################

# The port the backend server will listen on.
PORT=3000

# The environment mode (development, production, or test).
NODE_ENV=development

# Allowed origins for CORS (e.g., http://localhost:5173 for local frontend).
CORS_ORIGIN=http://localhost:5173

###################################
# AI Configuration
###################################

# The LLM provider to use. Valid options: 'claude', 'openai', 'gemini'.
AI_PROVIDER=claude

# API key for Anthropic (Claude 3.5 Sonnet). Required if AI_PROVIDER=claude.
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# API key for OpenAI (GPT-4o). Required if AI_PROVIDER=openai.
OPENAI_API_KEY=your_openai_api_key_here

# API key for Google Gemini (1.5 Pro). Required if AI_PROVIDER=gemini.
GEMINI_API_KEY=your_gemini_api_key_here
